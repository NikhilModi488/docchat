# Copy this file to ".env" and adjust as needed.
#   Windows PowerShell:  Copy-Item .env.example .env

# ===== LLM (local, via Ollama) ===========================================
OLLAMA_HOST=http://localhost:11434
RAG_LLM_MODEL=llama3.2
RAG_LLM_TEMPERATURE=0.1
RAG_LLM_NUM_PREDICT=1024

# ===== Embeddings ========================================================
# all-MiniLM-L6-v2 (default, fast/small) or BAAI/bge-small-en-v1.5
RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBED_DEVICE=auto          # auto | cpu | cuda
RAG_EMBED_BATCH=32

# ===== Chunking / ingestion ==============================================
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
# Chunking strategy: "page" (one chunk per page + cross-page overlap; oversized
# pages are sub-split) or "recursive" (classic size-based splitting).
RAG_CHUNK_STRATEGY=page
RAG_MAX_PAGE_CHARS=1600
RAG_MAX_FILE_MB=25
RAG_ENABLE_OCR=true            # needs the Tesseract binary on PATH
RAG_ENABLE_TABLES=true

# ===== Retrieval / reranking =============================================
RAG_TOP_K=5
RAG_FETCH_K=20
RAG_USE_HYBRID=true
RAG_HYBRID_ALPHA=0.5
RAG_USE_RERANKER=true
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_MAX_CONTEXT_CHARS=6000
# CrossEncoder scores are uncalibrated logits; keep this very low so only empty
# retrieval triggers the fallback (the LLM decides if context is insufficient).
RAG_MIN_RELEVANCE=-1e9

# ===== Evaluation (RAGAS) ================================================
RAG_ENABLE_RAGAS=true
RAG_RAGAS_FULL=false           # true = real RAGAS (heavy, needs judge LLM)

# ===== Auth ==============================================================
RAG_REQUIRE_AUTH=false         # true = all routes need a Bearer JWT
RAG_JWT_SECRET=change-me-in-production-please
RAG_TOKEN_EXPIRE_MIN=1440

# ===== Server ============================================================
RAG_DATABASE_URL=sqlite:///./db/rag.db
RAG_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RAG_RATE_LIMIT=60/minute
